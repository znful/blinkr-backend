# Copy to .env and fill in real values before running docker-compose.prod.yml.
# Never commit the real .env — it's already gitignored.

# Generate one with: uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me

DJANGO_DEBUG=false

# Comma-separated, e.g. example.com,www.example.com
DJANGO_ALLOWED_HOSTS=

POSTGRES_DB=blinkr
POSTGRES_USER=blinkr
POSTGRES_PASSWORD=change-me
